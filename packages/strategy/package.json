{
  "name": "@shuff/strategy",
  "version": "0.0.0",
  "description": "Shuffleboard shot strategy — candidate generation, exposure analysis, and Monte Carlo shot selection per docs/STRATEGY.md.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@shuff/core": "workspace:*",
    "@shuff/motion": "workspace:*"
  },
  "devDependencies": {
    "@shuff/core": "workspace:*",
    "@shuff/motion": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
